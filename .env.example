# MongoDB Atlas se connection string yahan daalein
# Free account: https://www.mongodb.com/cloud/atlas/register
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/wiscon?retryWrites=true&w=majority

# Koi bhi lamba random secret text (JWT token secure karne ke liye)
JWT_SECRET=change_this_to_a_long_random_secret_string

# Server port
PORT=5000

# Aapki website jis domain/URL par live hai (CORS ke liye)
# Local testing ke liye * bhi chalega
CLIENT_ORIGIN=*
